{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(npm install*)",
      "Bash(npm list*)",
      "Bash(node make_news_*.js)",
      "Bash(node --version)",
      "Bash(ls*)",
      "Bash(base64 -w 0 *.docx > /tmp/docx_b64.txt)",
      "Bash(cat /tmp/docx_b64.txt)",
      "Bash(git fetch origin main)",
      "Bash(git reset --hard origin/main)",
      "Bash(git log --oneline*)",
      "Bash(git status)"
    ]
  }
}
